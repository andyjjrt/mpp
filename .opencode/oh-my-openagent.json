{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "opencode-go/kimi-k2.5",
      "prompt_append": "Always delegate to hephaestus for implementation and sisyphus-junior for tasks. Parallelize exploration."
    },
    "sisyphus-junior": {
      "model": "opencode-go/minimax-m2.7"
    },
    "hephaestus": {
      "model": "openai/gpt-5.4",
      "prompt_append": "You are the primary implementation agent. Own the codebase. Explore, decide, execute. Use LSP and AST-grep aggressively.",
      "permission": {
        "edit": "allow",
        "bash": {
          "git": "allow",
          "test": "allow"
        }
      }
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "librarian": {
      "model": "github-copilot/grok-code-fast-1"
    },
    "explore": {
      "model": "github-copilot/grok-code-fast-1"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "prometheus": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "prompt_append": "Keep plans concise. Focus on file structure and key decisions."
    },
    "metis": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "opencode-go/kimi-k2.5"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "opencode-go/glm-5"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "quick": {
      "model": "github-copilot/gemini-3-flash-preview"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4",
      "variant": "medium"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "writing": {
      "model": "github-copilot/gemini-3-flash-preview"
    }
  },
  "background_task": {
    "defaultConcurrency": 8,
    "providerConcurrency": {
      "anthropic": 5,
      "openai": 5,
      "google": 10,
      "github-copilot": 10,
      "opencode": 15
    }
  },
  "hashline_edit": true,
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  }
}
