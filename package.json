{
  "name": "mouth-plus-plus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Discord OpenCode voice bot MVP",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write",
    "format:all": "prettier --write .",
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts",
    "register:commands": "tsx src/register-commands.ts"
  },
  "dependencies": {
    "@discordjs/voice": "0.19.2",
    "@opencode-ai/sdk": "1.14.19",
    "better-sqlite3": "^12.9.0",
    "discord.js": "14.26.3",
    "dotenv": "17.4.2",
    "ffmpeg-static": "^5.3.0",
    "openai": "^6.34.0",
    "opusscript": "0.0.8",
    "pino": "10.3.1",
    "undici": "6.25.0",
    "zod": "4.3.6",
    "prism-media": "^1.3.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "discord-api-types": "^0.38.47",
    "prettier": "3.5.3",
    "tsx": "^4.0.0",
    "typescript": "6.0.3",
    "vitest": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "ffmpeg-static"
    ]
  }
}
