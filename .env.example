# Discord bootstrap configuration
# Required bot token used for the Discord gateway login.
DISCORD_BOT_TOKEN=your_bot_token_here
# Required application/client ID used for slash-command registration in the next phase.
DISCORD_CLIENT_ID=your_application_client_id_here
# Required main text channel ID where bot mentions should be watched and session threads should begin.
DISCORD_MONITORED_CHANNEL_ID=your_monitored_text_channel_id_here
DISCORD_GUILD_ID=your_test_guild_id_here

# OpenCode configuration
OPENCODE_API_KEY=your_opencode_api_key_here
OPENCODE_BASE_URL=https://api.opencode.ai
# Optional: override the workspace directory sent to the OpenCode API.
# Leave unset to let the OpenCode API server use its own default directory.
# OPENCODE_DIRECTORY=/absolute/path/to/workspace

# OpenCode Basic Auth (alternative to API key)
# OPENCODE_SERVER_USERNAME=opencode
# OPENCODE_SERVER_PASSWORD=your_password_here

# ASR provider placeholders
ASR_API_KEY=your_asr_api_key_here
ASR_BASE_URL=https://your-asr-provider.example.com/v1
ASR_MODEL=your_asr_model_name

# Application configuration
LOG_LEVEL=info
NODE_ENV=development

# Completion notifications - mention users when AI response completes
ENABLE_COMPLETION_MENTION=false
ENABLE_COMPLETION_REPORT=true
